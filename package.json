{
  "name": "strutture-js",
  "version": "0.2.0",
  "type": "module",
  "description": "Codebase condivisa OOP per entita di calcolo strutturale in ingegneria civile.",
  "license": "MIT",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./applications": "./src/applications/index.js",
    "./norms/italian-historical": "./src/norms/italian-historical/index.js",
    "./norms/ntc2018": "./src/norms/ntc2018/index.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/run-tests.js",
    "check": "npm test && npm run validation",
    "syntax": "node scripts/check-syntax.js",
    "example": "node examples/basic-model.js",
    "example:ntc2018": "node examples/ntc2018-presets.js",
    "example:applications": "node examples/application-registry.js",
    "example:rc-sections": "node examples/rc-sections.js",
    "example:rc-sections:1000": "node examples/rc-sections-1000.js",
    "example:rc-deflection-report:simple-span": "node examples/write-rc-deflection-report-simple-span.js",
    "example:rc-deflection-report:fixed-fixed": "node examples/write-rc-deflection-report-fixed-fixed.js",
    "example:beam-reports": "node examples/beam-reports.js",
    "example:beam-reports:write": "node examples/write-beam-reports.js",
    "example:masonry-wall-openings:cerchiature": "node examples/write-masonry-wall-openings-cerchiature-reports.js",
    "validation": "node validation/run-validation.js"
  }
}
