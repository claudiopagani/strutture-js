{
  "name": "strutture-js",
  "version": "0.6.0",
  "type": "module",
  "sideEffects": false,
  "description": "Codebase condivisa OOP per entita di calcolo strutturale in ingegneria civile.",
  "license": "MIT",
  "main": "dist/index.mjs",
  "module": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./dist/index.mjs"
    },
    "./applications": "./src/applications/index.js",
    "./applications/*": "./src/applications/*/index.js",
    "./domain/fem": "./src/domain/fem/index.js",
    "./domain/math": "./src/domain/math/index.js",
    "./catalogs/steel-profiles": "./src/catalogs/steel-profiles.js",
    "./norms/italian-historical": "./src/norms/italian-historical/index.js",
    "./norms/ntc2018": "./src/norms/ntc2018/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "prepare": "npm run build",
    "test": "node --test tests/run-tests.js",
    "check": "npm test && npm run validation && npm run check:quality && npm run check:architecture && npm run check:worker-bundle",
    "syntax": "node scripts/check-syntax.js",
    "lint": "eslint src tests scripts examples validation",
    "typecheck": "tsc -p tsconfig.check.json",
    "check:quality": "npm run lint && npm run typecheck",
    "coverage": "node --test --experimental-test-coverage --test-coverage-include=src/**/*.js --test-coverage-exclude=src/config/** --test-coverage-lines=85 --test-coverage-branches=60 --test-coverage-functions=88 tests/run-tests.js",
    "check:performance": "node scripts/check-performance-budgets.js",
    "check:architecture": "node scripts/check-architecture.js",
    "check:worker-bundle": "npm run build && node scripts/check-web-worker-bundle.js",
    "benchmark:rc-moment-curvature": "node scripts/benchmark-rc-moment-curvature.js",
    "benchmark:rc-hyperstatic-deflection": "node scripts/benchmark-rc-hyperstatic-deflection.js",
    "benchmark:fem-constraints": "node scripts/benchmark-kinematic-reducer.js",
    "benchmark:fem-load-index": "node scripts/benchmark-element-load-index.js",
    "example": "node examples/basic-model.js",
    "example:ntc2018": "node examples/ntc2018-presets.js",
    "example:applications": "node examples/application-registry.js",
    "example:steel-consumer": "node examples/steel-beam-consumer.js",
    "example:rc-sections": "node examples/rc-sections.js",
    "example:rc-sections:1000": "node examples/rc-sections-1000.js",
    "example:rc-plates": "node examples/rc-plates.js",
    "example:rc-deflection-report:simple-span": "node examples/write-rc-deflection-report-simple-span.js",
    "example:rc-deflection-report:fixed-fixed": "node examples/write-rc-deflection-report-fixed-fixed.js",
    "example:beam-reports": "node examples/beam-reports.js",
    "example:beam-reports:write": "node examples/write-beam-reports.js",
    "example:masonry-wall-openings:cerchiature": "node examples/write-masonry-wall-openings-cerchiature-reports.js",
    "validation": "node validation/run-validation.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3"
  }
}
